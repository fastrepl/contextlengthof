# Default: load model_prices_and_context_window.json from GitHub (production).
#
# Local catalog API (litellm-model-catalog-api) + Vite proxy:
# 1. Terminal A: cd litellm-model-catalog-api && export MODEL_DATA_PATH=/path/to/litellm/model_prices_and_context_window.json
#    && uvicorn app:app --reload --host 127.0.0.1 --port 8000
# 2. Copy this file to .env.development and set:
VITE_USE_LOCAL_CATALOG_API=true
# Optional: override proxy target (default http://127.0.0.1:8000) in vite.config via:
# VITE_CATALOG_API_PROXY_TARGET=http://127.0.0.1:8000
#
# Call the API directly from the browser (CORS enabled on the API for :5173):
# VITE_USE_LOCAL_CATALOG_API=true
# VITE_CATALOG_API_BASE=http://127.0.0.1:8000
